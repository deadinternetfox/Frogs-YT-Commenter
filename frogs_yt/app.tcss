/* app.tcss — frog-green theme & layout for Frogs YouTube Replier */

Screen {
    background: $surface;
}

FrogBanner {
    width: 100%;
    height: auto;
    content-align: center top;
    padding: 1 0 0 0;
    color: $success;
}

/* Section titles */
.title {
    text-style: bold;
    color: $success;
    padding: 1 2 0 2;
}

.hint {
    color: $text-muted;
    padding: 0 2;
}

StatusPanel {
    border: round $success;
    padding: 1 2;
    margin: 1 2;
    width: 100%;
    height: auto;
    background: $surface;  /* solid so the pond bubbles stay behind, not through */
}

/* Dashboard ambient background — a subtle bubble field behind everything. */
DashboardScreen {
    layers: pond ui;
}

#pond {
    layer: pond;
    width: 100%;
    height: 100%;
    background: transparent;
}

/* Vertical menu of buttons on the dashboard */
#menu {
    align: center middle;
    padding: 1 2;
    height: auto;
}

#menu Button {
    width: 36;
    margin: 1 0;
}

/* Generic form layout */
.form {
    padding: 1 2;
    height: auto;
}

.form Label {
    padding: 1 0 0 0;
    text-style: bold;
}

.form Input, .form TextArea, .form Select {
    margin: 0 0 1 0;
}

/* TextArea defaults to height: 1fr, which collapses to nothing inside an
   auto-height form — so every form TextArea (keywords, reply prompt) needs an
   explicit height to show and accept input. */
.form TextArea {
    height: 8;
}

#prompt {
    height: 12;
}

.row {
    height: auto;
    layout: horizontal;
}

.row Input {
    width: 1fr;
    margin: 0 1 1 0;
}

.actions {
    height: auto;
    padding: 1 2;
    align: left middle;
}

.actions Button {
    margin: 0 2 0 0;
}

/* Data tables on the harvest screen */
#videos-table {
    height: 40%;
    margin: 0 2;
}

#comments-table {
    height: 1fr;
    margin: 0 2;
}

/* Review screen */
#comment-panel {
    border: round $primary;
    padding: 1 2;
    margin: 1 2;
    height: auto;
}

#draft-area {
    height: 10;
    margin: 0 2 1 2;
}

#queue-pos {
    color: $text-muted;
    padding: 0 2;
}

/* Auto-post log */
#autopost-log {
    border: round $primary;
    margin: 1 2;
    height: 1fr;
}

ProgressBar {
    margin: 1 2;
}

/* Confirm modal */
#confirm-grid {
    grid-size: 2 2;
    grid-gutter: 1 2;
    grid-rows: 1fr 3;
    padding: 2 4;
    width: 64;
    height: 14;
    border: thick $error 60%;
    background: $panel;
}

#confirm-question {
    column-span: 2;
    height: 1fr;
    content-align: center middle;
}

#status-line {
    color: $text-muted;
    padding: 0 2;
    height: auto;
}

/* Help overlay */
#help-box {
    width: 80;
    max-width: 90%;
    height: auto;
    max-height: 90%;
    padding: 1 3;
    margin: 2 4;
    border: thick $success 70%;
    background: $panel;
}

HelpModal {
    align: center middle;
    background: $background 70%;
}

ConfirmModal {
    align: center middle;
    background: $background 70%;
}

/* Preset save / open modals */
SavePresetModal, PresetPickerModal {
    align: center middle;
    background: $background 70%;
}

#save-preset-box {
    width: 64;
    max-width: 90%;
    height: auto;
    padding: 1 3 0 3;
    border: thick $success 70%;
    background: $panel;
}

#save-preset-title, #preset-picker-title {
    text-style: bold;
    color: $success;
    padding: 0 0 1 0;
}

#save-preset-hint {
    height: 1;
    padding: 0 0 1 0;
}

#preset-picker-box {
    width: 72;
    max-width: 92%;
    height: auto;
    max-height: 90%;
    padding: 1 3 0 3;
    border: thick $success 70%;
    background: $panel;
}

#preset-list {
    height: auto;
    max-height: 16;
    margin: 0 0 1 0;
    border: round $primary;
    background: $surface;
}

#preset-picker-hint {
    color: $text-muted;
    padding: 0 0 1 0;
}
